\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Cross-model comparison of 7B-parameter models using MMSP Method C (Tier~1, TADN). (a)~Qwen2.5-7B-Instruct: instruction-following model with loss range 43.9 and higher roughness (0.72). (b)~OLMo-3-7B-Think: reasoning-focused model with dramatically flatter landscape (loss range 13.4, roughness 0.30). Despite similar parameter counts, different training objectives produce distinct landscape geometries.}}{10}{figure.caption.12}\protected@file@percent }
\newlabel{fig:crossmodel}{{6}{10}{Cross-model comparison of 7B-parameter models using MMSP Method C (Tier~1, TADN). (a)~Qwen2.5-7B-Instruct: instruction-following model with loss range 43.9 and higher roughness (0.72). (b)~OLMo-3-7B-Think: reasoning-focused model with dramatically flatter landscape (loss range 13.4, roughness 0.30). Despite similar parameter counts, different training objectives produce distinct landscape geometries}{figure.caption.12}{}}
