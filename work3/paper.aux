\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces TADN scale invariance test. (a) 1D cross-sections along TADN-normalized and LayerNorm-normalized directions before and after non-uniform FFN neuron rescaling. TADN cross-sections overlap perfectly (dashed line hidden behind solid); LayerNorm cross-sections diverge. (b) Quantitative comparison: TADN achieves correlation $= 1.000$ and MSE $= 0.0$; LayerNorm correlation $= 0.918$, MSE $= 28.5$.}}{6}{figure.caption.3}\protected@file@percent }
\newlabel{fig:tadn}{{2}{6}{TADN scale invariance test. (a) 1D cross-sections along TADN-normalized and LayerNorm-normalized directions before and after non-uniform FFN neuron rescaling. TADN cross-sections overlap perfectly (dashed line hidden behind solid); LayerNorm cross-sections diverge. (b) Quantitative comparison: TADN achieves correlation $= 1.000$ and MSE $= 0.0$; LayerNorm correlation $= 0.918$, MSE $= 28.5$}{figure.caption.3}{}}
